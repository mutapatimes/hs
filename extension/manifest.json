{
  "manifest_version": 3,
  "name": "Halia — client grades where you work",
  "version": "0.1.0",
  "description": "Surfaces a client's Halia grade, reasons and next move inside your store admin, WhatsApp Web and Gmail. Reads nothing, stores nothing.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Halia",
    "default_icon": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
  },
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "options_page": "options.html",
  "permissions": ["storage", "scripting", "contextMenus", "notifications", "alarms"],
  "host_permissions": [
    "https://haliascore.com/*",
    "https://*.onrender.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "optional_host_permissions": ["*://*/*"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": [
        "https://admin.shopify.com/*",
        "https://*.myshopify.com/admin/*",
        "https://*.mybigcommerce.com/manage/*"
      ],
      "js": ["ui/badge.js", "content/core.js", "content/admin.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["ui/badge.js", "content/core.js", "content/whatsapp.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["ui/badge.js", "content/core.js", "content/gmail.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://app.slack.com/*"],
      "js": ["ui/badge.js", "content/core.js", "content/slack.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["ui/badge.js", "content/core.js", "content/instagram.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://calendar.google.com/*"],
      "js": ["ui/badge.js", "content/core.js", "content/calendar.js"],
      "run_at": "document_idle"
    }
  ]
}
